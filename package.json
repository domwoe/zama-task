{
  "name": "zama-confidential-indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "ponder dev",
    "typecheck": "tsc --noEmit --pretty false",
    "lint": "eslint .",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "build:test-contracts": "forge build",
    "ponder:codegen": "ponder codegen",
    "check": "pnpm run ponder:codegen && pnpm run typecheck && pnpm run lint && pnpm run test",
    "reset:local-db": "rm -rf ./.ponder/pglite",
    "demo:doctor": "node --env-file=.env.local --experimental-strip-types scripts/demo-doctor.ts",
    "demo:seed": "node --env-file=.env.local --experimental-strip-types scripts/demo-seed.ts",
    "demo:delegate": "node --env-file=.env.local --experimental-strip-types scripts/delegate-indexer.ts",
    "demo:revoke": "node --env-file=.env.local --experimental-strip-types scripts/revoke-indexer.ts",
    "demo:watch": "node --env-file=.env.local --experimental-strip-types scripts/demo-watch.ts"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.13",
    "@eslint/js": "^10.0.1",
    "@types/emscripten": "^1.41.5",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/semver": "^7.7.1",
    "@viem/anvil": "^0.0.10",
    "eslint": "^10.4.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@zama-fhe/sdk": "^3.1.0-alpha.4",
    "drizzle-orm": "0.41.0",
    "hono": "^4.12.23",
    "ponder": "^0.16.6",
    "viem": "^2.52.2",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "keccak"
    ],
    "overrides": {
      "@hono/node-server": ">=1.19.13",
      "esbuild": ">=0.25.0",
      "ws": ">=8.20.1"
    },
    "patchedDependencies": {
      "@zama-fhe/sdk@3.1.0-alpha.4": "patches/@zama-fhe__sdk@3.1.0-alpha.4.patch"
    }
  }
}

{
  "name": "zama-confidential-indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "ponder dev",
    "typecheck": "tsc --noEmit --pretty false",
    "lint": "eslint .",
    "test": "vitest run",
    "ponder:codegen": "ponder codegen",
    "check": "pnpm run ponder:codegen && pnpm run typecheck && pnpm run lint && pnpm run test",
    "reset:local-db": "rm -rf ./.ponder/pglite",
    "demo:seed": "node --experimental-strip-types scripts/demo-seed.ts",
    "demo:delegate": "node --experimental-strip-types scripts/delegate-indexer.ts",
    "demo:revoke": "node --experimental-strip-types scripts/revoke-indexer.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/emscripten": "^1.41.5",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/semver": "^7.7.1",
    "eslint": "^10.4.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@zama-fhe/sdk": "^3.1.0-alpha.4",
    "hono": "^4.12.23",
    "ponder": "^0.16.6",
    "viem": "^2.52.2",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "keccak"
    ],
    "overrides": {
      "@hono/node-server": ">=1.19.13",
      "esbuild": ">=0.25.0",
      "vite": ">=6.4.2",
      "ws": ">=8.20.1"
    }
  }
}

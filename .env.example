# ─────────────────────────────────────────────────────────────────────────────
# Zama Confidential Indexer — copy to .env.local, then fill the REQUIRED block.
#
#   cp .env.example .env.local
#
# Everything below REQUIRED is prefilled with the public Zama Sepolia demo
# contracts and sensible defaults — leave it as-is to run the demo.
# Validate your .env.local before seeding:  pnpm run demo:doctor
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED — generate throwaway keys, fund the holder ──────────────────────
# Generate a keypair (run twice: once for the indexer, once for the holder):
#   node --input-type=module -e "import {generatePrivateKey, privateKeyToAccount} from 'viem/accounts'; const k=generatePrivateKey(); console.log(k, privateKeyToAccount(k).address)"

# Indexer's own EOA. Decrypts as a delegate off-chain, so it needs NO ETH.
# The address must derive from the key (demo:doctor verifies this).
INDEXER_ADDRESS=
INDEXER_PRIVATE_KEY=

# Holder that shields, transfers, and delegates.
# NEEDS ~0.02 Sepolia ETH for gas — faucet: https://sepolia-faucet.pk910.de
DEMO_HOLDER_PRIVATE_KEY=

# Recipient of the demo transfer (any third address; needs no ETH).
DEMO_RECIPIENT_ADDRESS=

# Holders to scope the indexer to — set to the holder + recipient addresses,
# comma-separated. Leave blank to index every address on the token.
INDEXED_ADDRESSES=

# ── Prefilled — public Zama Sepolia demo contracts (ready to use) ────────────
# cUSDTMock confidential wrapper (6 decimals) over a mintable USDT mock.
TOKEN_ADDRESS=0x4E7B06D78965594eB5EF5414c357ca21E1554491
FHEVM_ACL_ADDRESS=0xf0Ffdc93b7E186bC2f8CB3dAA75D86d1930A433D

# Keyless public Sepolia node — swap in your own if it rate-limits.
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Block to index from, or `latest` for the chain head.
START_BLOCK=latest

# ── Prefilled — demo amounts (base units; the token has 6 decimals) ──────────
# Blank skips that step. Mint/shield are underlying units; transfer is wrapped.
# mint 1.0 underlying to the holder
DEMO_MINT_AMOUNT=1000000
# shield 1.0 into the confidential wrapper
DEMO_SHIELD_AMOUNT=1000000
# confidential-transfer 0.25 to the recipient
DEMO_TRANSFER_AMOUNT=250000
# optional — blank skips the unshield step
DEMO_UNSHIELD_AMOUNT=

# ── Optional ─────────────────────────────────────────────────────────────────
# The public Zama relayer needs no key; set only if you have one.
RELAYER_API_KEY=

# Where demo:watch reads the API.
API_BASE_URL=http://localhost:42069

# SDK worker/cache/event logs for pnpm run dev: silent, error, warn, info, or debug.
ZAMA_SDK_LOG_LEVEL=debug
